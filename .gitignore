# ===========================
# Python
# ===========================
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# ===========================
# 環境變數與機敏資訊
# ===========================
.env
.env.local
.env.*.local
!.env.example

# ===========================
# AI IDE 工具（個人設定）
# ===========================
.claude/*
!.claude/rules/
.aider*
.continue/
.copilot/

# ===========================
# IDE / 編輯器
# ===========================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===========================
# Agent 執行期工作區產出
# （透過 .gitkeep 保留目錄結構，忽略實際產出檔案）
# ===========================
workspace/**
!workspace/**/
!workspace/**/.gitkeep

# ===========================
# Agent Skills Symlink（由 mapper.sh 產生）
# ===========================
.agents/skills/*
!.agents/skills/.gitkeep

# ===========================
# 系統與暫存
# ===========================
*.log
*.tmp
*.bak
