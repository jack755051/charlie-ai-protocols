# ===========================
# Python
# ===========================
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# ===========================
# 環境變數與機敏資訊
# ===========================
.env
.env.local
.env.*.local
!.env.example

# ===========================
# AI IDE 工具（個人設定）
# ===========================
.claude/*
!.claude/rules/
.aider*
.continue/
.copilot/
.codex
.codex/

# ===========================
# IDE / 編輯器
# ===========================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===========================
# Agent 執行期工作區產出
# （透過 .gitkeep 保留目錄結構，忽略實際產出檔案）
# ===========================
workspace/**
!workspace/**/
!workspace/**/.gitkeep

# ===========================
# CAP self-hosting fresh e2e artifacts
# When this repo is used as a fixture target for cap workflow run, the
# spec-pipeline writes PRD / API / UI / design artifacts under docs/specs,
# docs/architecture, docs/design relative to the project root. The platform
# SSOT lives in docs/cap/, agent-skills/, policies/, schemas/, engine/, and
# scripts/ — these run artifact directories are runtime output, not source.
# ===========================
docs/specs/
docs/architecture/
docs/design/

# ===========================
# Agent Skills Symlink（由 mapper.sh 產生）
# ===========================
.agents/skills/*
!.agents/skills/.gitkeep

# ===========================
# 系統與暫存
# ===========================
*.log
*.tmp
*.bak
